# Copy this file to .env.local and fill in local secrets.
PORT=8787
CORS_ORIGIN=http://127.0.0.1:5173

# Volcengine Ark Responses API settings.
ARK_API_KEY=replace-with-your-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-0-lite-260215
ARK_DEFAULT_MAX_OUTPUT_TOKENS=4096
API_TIMEOUT_MS=3000000


